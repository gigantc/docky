rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Dock stores notes, journals, briefs in this collection
    match /notes/{noteId} {
      allow read, write: if signedIn();
    }

    // Dock lists
    match /lists/{listId} {
      allow read, write: if signedIn();
    }

    // Journals: top-level journal docs + nested entries subcollection
    match /journals/{journalId} {
      allow read, write: if signedIn();

      match /entries/{entryId} {
        allow read, write: if signedIn();
      }
    }

    // Allow collectionGroup('entries') queries across all journals
    match /{path=**}/entries/{entryId} {
      allow read: if signedIn();
    }

    // deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
